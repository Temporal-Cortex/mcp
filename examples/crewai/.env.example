# Required for Google Calendar (see docs/google-cloud-setup.md)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Required for Microsoft Outlook (see docs/outlook-setup.md)
# MICROSOFT_CLIENT_ID=your-client-id
# MICROSOFT_CLIENT_SECRET=your-client-secret

# Optional timezone override (auto-detected if not set)
# TIMEZONE=America/New_York

# For Platform Mode (SSE transport) — get from app.temporal-cortex.com
# TEMPORAL_CORTEX_API_KEY=sk_live_...
